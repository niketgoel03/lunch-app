# Copy to .env and edit. Never commit the real .env.

PORT=3000

# Long random string used to sign session tokens.
JWT_SECRET=change-me-to-a-long-random-string

# First admin user, created automatically on first run.
ADMIN_EMAIL=admin@office.local
ADMIN_NAME=Office Admin

# Default daily rules (changeable later in the Admin tab).
DEFAULT_CUTOFF_TIME=13:00
DEFAULT_AGGREGATE_TIME=13:05
TIMEZONE=Asia/Kolkata
CURRENCY=INR

# Initial allowed email domains for self-onboarding (comma-separated; editable in Admin tab).
# Blank = no self sign-up (only admin-added people can log in).
ALLOWED_DOMAINS=

# ---------- PostgreSQL ----------
# Either set a single DATABASE_URL ...
DATABASE_URL=postgresql://lunch:secret@localhost:5432/lunchdb
# ... or the discrete vars (used only if DATABASE_URL is unset):
# PGHOST=localhost
# PGPORT=5432
# PGUSER=lunch
# PGPASSWORD=secret
# PGDATABASE=lunchdb
# Set true for managed/cloud Postgres requiring TLS:
PGSSL=false

# ---------- Email / OTP delivery ----------
#   graph   = Microsoft Graph (recommended for Microsoft 365)
#   smtp    = classic SMTP
#   console = development only: OTP printed to server log + shown in UI
MAIL_TRANSPORT=graph
MAIL_FROM=lunch@office.local

# Microsoft Graph (app registration with APPLICATION permission Mail.Send + admin consent).
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
# Mailbox that sends the OTP (UPN or object id), e.g. lunch@yourcompany.com
GRAPH_SENDER=

# SMTP (only if MAIL_TRANSPORT=smtp)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Set true only when served over HTTPS (sets the Secure cookie flag).
COOKIE_SECURE=false
